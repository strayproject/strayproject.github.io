---
import SheetPageLayout from "../layouts/SheetPageLayout.astro";
import { Image } from "astro:assets";
import lineImage from "../assets/stranded/itch/line.webp";

const installDownloads = [
  {
    key: "windows-linux",
    label: "Download Windows / Linux",
    href: "https://github.com/strayproject/strayproject.github.io/releases/download/v0.3.0/Stranded-0.3.0-pc.zip",
    icons: ["fa-brands fa-windows", "fa-brands fa-linux"],
  },
  {
    key: "mac",
    label: "Download Mac",
    href: "https://github.com/strayproject/strayproject.github.io/releases/download/v0.3.0/Stranded-0.3.0-mac.zip",
    icons: ["fa-brands fa-apple"],
  },
  {
    key: "android",
    label: "Download Android",
    href: "https://github.com/strayproject/strayproject.github.io/releases/download/v0.3.0/com.strayproject.stranded-0.3.0-1777106477-release.apk",
    icons: ["fa-brands fa-android"],
  },
];

const firstInstallCards = [
  {
    title: "Windows / Linux",
    icon: "fa-brands fa-windows",
    extraIcon: "fa-brands fa-linux",
    steps: [
      "Download the game .zip file and open it.",
      "Drag the folder inside the zip to a normal location such as your desktop, downloads folder, or games folder.",
      "Open the extracted folder and launch the file that matches your system.",
    ],
    notes: [
      "64-bit Windows: Stranded.exe",
      "32-bit Windows: Stranded-32.exe",
      "64-bit Linux: Stranded.sh",
    ],
    detail:
      "On Linux, if the file opens in a text editor instead of launching, right-click Stranded.sh and choose Run as Program. If needed, open a terminal in that folder and run chmod +x Stranded.sh && ./Stranded.sh.",
  },
  {
    title: "Mac",
    icon: "fa-brands fa-apple",
    steps: [
      "Download the game .zip file and open it.",
      "Drag the app inside the zip to your preferred folder, such as Applications.",
      "Double-click the app to launch it.",
    ],
    detail:
      "If macOS blocks the app, Control-click it, choose Open, then choose Open again in the warning prompt. If you still hit a permissions issue, move the app out of the zip first and try again.",
  },
  {
    title: "Android",
    icon: "fa-solid fa-mobile-screen",
    steps: [
      "Download the game .apk file, then open it.",
      "If Android shows a security warning, tap Settings.",
      "Enable installation from this source.",
      "Return to the installer and tap Install.",
    ],
    images: [
      {
        src: "/assets/img/sc/android_denied.webp",
        alt: "Android warning screen with a Settings button.",
        caption: "1. Tap Settings.",
        width: 360,
        height: 178,
      },
      {
        src: "/assets/img/sc/android_allow.webp",
        alt: "Android settings screen with install from this source enabled.",
        caption: "2. Allow this source.",
        width: 360,
        height: 170,
      },
      {
        src: "/assets/img/sc/android_install.webp",
        alt: "Android installer screen with the Install button visible.",
        caption: "3. Go back and install.",
        width: 360,
        height: 164,
      },
    ],
  },
];
---

<SheetPageLayout
  title="Installation"
  description="Follow these instructions to install the game."
  image="/assets/img/bg/campfire.webp"
>
      <section class="text-center">
        <div class="mx-auto max-w-4xl text-center">
          <h1 id="download" class="inline-flex items-center justify-center gap-2 text-2xl sm:text-3xl">
            <img
              class="h-10 w-10 flex-none sm:h-12 sm:w-12"
              src="/assets/img/emotes/love.webp"
              alt=""
              width="64"
              height="64"
              aria-hidden="true"
            />
            Thank you for downloading!
          </h1>
          <div class="mt-5 flex flex-wrap justify-center gap-3 text-base sm:text-lg">
            {installDownloads.map((download) => (
              <a
                class="install-download-button flex w-full items-center justify-center gap-2 rounded bg-[#9fbe57] px-5 py-2.5 text-white shadow transition duration-150 hover:bg-[#87a743] focus:outline-none focus:ring-2 focus:ring-[#5f792f] focus:ring-offset-2 sm:w-auto"
                href={download.href}
                data-download-option={download.key}
              >
                <span class="inline-flex items-center gap-1.5" aria-hidden="true">
                  {download.icons.map((icon) => (
                    <i class={icon}></i>
                  ))}
                </span>
                <span>{download.label}</span>
              </a>
            ))}
          </div>
        </div>
      </section>

      <div class="space-y-12">
        <section aria-labelledby="first-installation" class="space-y-5">
          <Image class="mx-auto mb-5 w-full max-w-[560px]" src={lineImage} alt="" loading="lazy" />
          <div class="text-center">
            <h2 id="first-installation" class="text-2xl sm:text-3xl">
              First Installation
            </h2>
          </div>

          <div class="grid gap-4">
            {firstInstallCards.map((card) => (
              <section class="rounded-[10px] border border-[rgba(95,121,47,0.2)] bg-[rgba(237,243,228,0.74)] p-4 shadow-sm sm:p-5">
                <h3 class="text-2xl text-[#40551f] sm:text-3xl">
                  <i class={card.icon}></i>
                  {card.extraIcon && <i class={`${card.extraIcon} pl-2`}></i>}
                  <span class="pl-2">{card.title}</span>
                </h3>
                <ol class="mt-4 space-y-2 pl-6 text-base leading-snug text-[#3f433b] marker:text-[#5f792f] sm:text-lg">
                  {card.steps.map((step) => (
                    <li>{step}</li>
                  ))}
                </ol>

                {card.notes && (
                  <ul class="mt-3 list-disc space-y-1.5 pl-6 text-base leading-snug text-[#3f433b] sm:text-lg">
                    {card.notes.map((note) => (
                      <li>{note}</li>
                    ))}
                  </ul>
                )}

                {card.detail && (
                  <div class="mt-4 rounded-[10px] border border-[rgba(95,121,47,0.16)] bg-[#f8f8f5] p-4 text-base leading-snug text-[#3f433b] sm:text-lg">
                    {card.detail}
                  </div>
                )}

                {card.images && (
                  <div class="mt-5 grid gap-3 sm:grid-cols-3">
                    {card.images.map((image) => (
                      <figure class="rounded-[10px] border border-[rgba(95,121,47,0.16)] bg-[#f8f8f5] p-3 text-center">
                        <img
                          class="mx-auto rounded-[10px]"
                          src={image.src}
                          alt={image.alt}
                          width={image.width}
                          height={image.height}
                          loading="lazy"
                        />
                        <figcaption class="mt-2 text-base text-[#3f433b] sm:text-lg">{image.caption}</figcaption>
                      </figure>
                    ))}
                  </div>
                )}
              </section>
            ))}
          </div>
        </section>

        <section aria-labelledby="updating-current-build" class="space-y-5">
          <Image class="mx-auto mb-5 w-full max-w-[560px]" src={lineImage} alt="" loading="lazy" />
          <div class="text-center">
            <h2 id="updating-current-build" class="text-2xl sm:text-3xl">
              Updating Current Build
            </h2>
            <p class="mx-auto mt-3 max-w-[620px] text-base leading-snug text-[#3f433b] sm:text-lg">
              Updating is mostly the same as a first install, with one important
              Android warning.
            </p>
          </div>

          <div class="grid gap-4">
            <section class="rounded-[10px] border border-[rgba(95,121,47,0.2)] bg-[rgba(237,243,228,0.74)] p-4 shadow-sm sm:p-5">
              <h3 class="text-2xl text-[#40551f] sm:text-3xl">
                <i class="fa-brands fa-windows pr-2"></i><i class="fa-brands fa-linux pr-2"></i><i class="fa-brands fa-apple pr-2"></i>
                Windows / Linux / Mac
              </h3>
              <ol class="mt-4 space-y-2 pl-6 text-base leading-snug text-[#3f433b] marker:text-[#5f792f] sm:text-lg">
                <li>Download the newest build.</li>
                <li>Extract or move it just like you did the first time.</li>
                <li>Open the new version from its folder or app file.</li>
              </ol>
              <div class="mt-4 rounded-[10px] border border-[rgba(95,121,47,0.16)] bg-[#f8f8f5] p-4 text-base leading-snug text-[#3f433b] sm:text-lg">
                Your saves are stored in a different folder, so replacing the
                old build will not remove them. You can safely delete the older
                game files after confirming the new version launches correctly.
              </div>
              <p class="mt-4 text-base leading-snug text-[#3f433b] sm:text-lg">
                One caution: loading a save made in a newer build with an older
                build can cause errors.
              </p>
            </section>

            <section class="rounded-[10px] border border-[rgba(95,121,47,0.2)] bg-[rgba(237,243,228,0.74)] p-4 shadow-sm sm:p-5">
              <h3 class="text-2xl text-[#40551f] sm:text-3xl">
                <i class="fa-solid fa-mobile-screen pr-2"></i>Android
              </h3>
              <div class="mt-4 rounded-[10px] border border-[rgba(95,121,47,0.22)] bg-[#edf3e4] p-4 text-base leading-snug text-[#3f433b] sm:text-lg">
                <strong>Do not uninstall the previous app</strong> if you want
                to keep your saves. Uninstalling the old app can delete your
                save data.
              </div>
              <figure class="mt-4 rounded-[10px] border border-[rgba(95,121,47,0.16)] bg-[#f8f8f5] p-3 text-center">
                <img
                  class="mx-auto rounded-[10px]"
                  src="/assets/img/sc/android_update.webp"
                  alt="Android update prompt showing the Install button for the new version."
                  width="360"
                  height="163"
                  loading="lazy"
                />
                <figcaption class="mt-2 text-base text-[#3f433b] sm:text-lg">
                  Open the new .apk, then tap Install.
                </figcaption>
              </figure>
              <p class="mt-4 text-base leading-snug text-[#3f433b] sm:text-lg">
                Download the new .apk and install it over the existing version.
                That keeps your saves in place.
              </p>
            </section>
          </div>
        </section>

        <section
          id="help"
          aria-labelledby="need-help"
          class="rounded-[10px] border border-[rgba(95,121,47,0.2)] bg-[rgba(237,243,228,0.74)] px-5 py-6 shadow-sm"
        >
          <h2 id="need-help" class="text-center text-2xl sm:text-3xl">
            Need Help?
          </h2>
          <div class="mx-auto mt-4 grid max-w-4xl gap-4 sm:grid-cols-3">
            <a
              href="/stranded.html#download"
              class="rounded-[10px] border border-[rgba(95,121,47,0.16)] bg-[#f8f8f5] px-4 py-4 text-center text-base text-[#20231f] shadow-sm transition duration-150 hover:bg-[#edf3e4] sm:text-lg"
            >
              Return to the Stranded download page
            </a>
            <a
              href="https://discord.gg/4Rp2sVzAHk"
              class="rounded-[10px] border border-[rgba(95,121,47,0.16)] bg-[#f8f8f5] px-4 py-4 text-center text-base text-[#20231f] shadow-sm transition duration-150 hover:bg-[#edf3e4] sm:text-lg"
            >
              Ask for help in Discord
            </a>
            <a
              href="https://github.com/strayproject/strayproject.github.io/releases"
              class="rounded-[10px] border border-[rgba(95,121,47,0.16)] bg-[#f8f8f5] px-4 py-4 text-center text-base text-[#20231f] shadow-sm transition duration-150 hover:bg-[#edf3e4] sm:text-lg"
            >
              Check the latest releases
            </a>
          </div>
        </section>
      </div>
  <style>
    .install-download-button.is-selected {
      background-color: #779350;
      box-shadow:
        0 0 0 2px #f8f8f5,
        0 0 0 4px #5f792f;
    }
  </style>

  <script is:inline>
    const selectedDownload = new URLSearchParams(window.location.search).get("download");
    if (selectedDownload) {
      document.querySelectorAll("[data-download-option]").forEach((button) => {
        if (button.getAttribute("data-download-option") === selectedDownload) {
          button.classList.add("is-selected");
        }
      });
    }
  </script>
</SheetPageLayout>
