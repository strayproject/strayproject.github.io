---
import BaseLayout from "../layouts/BaseLayout.astro";

const firstInstallCards = [
  {
    title: "Windows / Linux",
    icon: "fa-brands fa-windows",
    extraIcon: "fa-brands fa-linux",
    tone: "bg-sky-50 ring-sky-200",
    steps: [
      "Download the game .zip file and open it.",
      "Drag the folder inside the zip to a normal location such as your desktop, downloads folder, or games folder.",
      "Open the extracted folder and launch the file that matches your system.",
    ],
    notes: [
      "64-bit Windows: Stranded.exe",
      "32-bit Windows: Stranded-32.exe",
      "64-bit Linux: Stranded.sh",
    ],
    detail:
      "On Linux, if the file opens in a text editor instead of launching, right-click Stranded.sh and choose Run as Program. If needed, open a terminal in that folder and run chmod +x Stranded.sh && ./Stranded.sh.",
  },
  {
    title: "Mac",
    icon: "fa-brands fa-apple",
    tone: "bg-rose-50 ring-rose-200",
    steps: [
      "Download the game .zip file and open it.",
      "Drag the app inside the zip to your preferred folder, such as Applications.",
      "Double-click the app to launch it.",
    ],
    detail:
      "If macOS blocks the app, Control-click it, choose Open, then choose Open again in the warning prompt. If you still hit a permissions issue, move the app out of the zip first and try again.",
  },
  {
    title: "Android",
    icon: "fa-solid fa-mobile-screen",
    tone: "bg-amber-50 ring-amber-200",
    steps: [
      "Download the game .apk file, then open it.",
      "If Android shows a security warning, tap Settings.",
      "Enable installation from this source.",
      "Return to the installer and tap Install.",
    ],
    images: [
      {
        src: "/assets/img/sc/android_denied.webp",
        alt: "Android warning screen with a Settings button.",
        caption: "1. Tap Settings.",
      },
      {
        src: "/assets/img/sc/android_allow.webp",
        alt: "Android settings screen with install from this source enabled.",
        caption: "2. Allow this source.",
      },
      {
        src: "/assets/img/sc/android_install.webp",
        alt: "Android installer screen with the Install button visible.",
        caption: "3. Go back and install.",
      },
    ],
  },
];
---

<BaseLayout
  title="Installation"
  description="Follow these instructions to install the game."
  image="/assets/img/bg/campfire.webp"
>
  <div
    class="fixed inset-0 -z-10 bg-cover bg-center"
    style="background-image: url('/assets/stranded/itch/background.webp');"
  ></div>

  <div class="mx-auto max-w-6xl px-3 pt-4 font-boogaloo sm:px-4 lg:px-6 lg:pt-8">
    <div class="stranded-sheet overflow-hidden">
      <section class="border-b border-orange-200/70 bg-gradient-to-br from-orange-50/90 via-amber-50/90 to-sky-100/80 px-4 py-8 sm:px-6 lg:px-10">
        <div class="mx-auto max-w-4xl text-center">
          <h1 id="download" class="text-4xl sm:text-5xl lg:text-6xl">
            Thank you for downloading!
          </h1>
          <p class="mx-auto mt-4 max-w-2xl text-xl text-gray-800 sm:text-2xl">
            Pick your platform below for the fastest way to get Stranded
            running. If anything feels off, the help links at the bottom will
            point you in the right direction.
          </p>
          <div class="mt-6 flex flex-wrap justify-center gap-3 text-lg sm:text-xl">
            <a
              href="/stranded.html#download"
              class="rounded-full bg-red-800 px-5 py-2 text-white transition duration-150 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-700 focus:ring-offset-2"
            >
              Back to downloads
            </a>
            <a
              href="#help"
              class="rounded-full border border-red-800 px-5 py-2 text-red-900 transition duration-150 hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-700 focus:ring-offset-2"
            >
              Troubleshooting help
            </a>
          </div>
        </div>
      </section>

      <div class="space-y-10 px-4 py-6 sm:px-6 lg:px-10 lg:py-10">
        <section aria-labelledby="first-installation" class="space-y-5">
          <div class="text-center">
            <h2 id="first-installation" class="text-3xl sm:text-4xl lg:text-5xl">
              First Installation
            </h2>
            <p class="mt-2 text-lg text-gray-700 sm:text-xl">
              Each platform has slightly different steps, so choose the card
              that matches your device.
            </p>
          </div>

          <div class="grid gap-5 lg:grid-cols-3">
            {firstInstallCards.map((card) => (
              <section class={`rounded-3xl p-5 shadow-sm ring-1 ${card.tone}`}>
                <h3 class="text-2xl text-red-800 sm:text-3xl">
                  <i class={card.icon}></i>
                  {card.extraIcon && <i class={`${card.extraIcon} pl-2`}></i>}
                  <span class="pl-2">{card.title}</span>
                </h3>
                <ol class="mt-4 space-y-3 pl-6 text-lg marker:text-red-700 sm:text-xl">
                  {card.steps.map((step) => (
                    <li>{step}</li>
                  ))}
                </ol>

                {card.notes && (
                  <ul class="mt-3 list-disc space-y-2 pl-10 text-lg sm:text-xl">
                    {card.notes.map((note) => (
                      <li>{note}</li>
                    ))}
                  </ul>
                )}

                {card.detail && (
                  <div class="mt-4 rounded-2xl bg-white/80 p-4 text-lg text-gray-800 ring-1 ring-white/70 sm:text-xl">
                    {card.detail}
                  </div>
                )}

                {card.images && (
                  <div class="mt-5 grid gap-3 sm:grid-cols-3">
                    {card.images.map((image) => (
                      <figure class="rounded-2xl bg-white/80 p-3 text-center ring-1 ring-white/70">
                        <img
                          class="mx-auto rounded-xl"
                          src={image.src}
                          alt={image.alt}
                          loading="lazy"
                        />
                        <figcaption class="mt-2 text-lg">{image.caption}</figcaption>
                      </figure>
                    ))}
                  </div>
                )}
              </section>
            ))}
          </div>
        </section>

        <section aria-labelledby="updating-current-build" class="space-y-5">
          <div class="text-center">
            <h2 id="updating-current-build" class="text-3xl sm:text-4xl lg:text-5xl">
              Updating Current Build
            </h2>
            <p class="mt-2 text-lg text-gray-700 sm:text-xl">
              Updating is mostly the same as a first install, with one important
              Android warning.
            </p>
          </div>

          <div class="grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
            <section class="rounded-3xl bg-emerald-50 p-5 shadow-sm ring-1 ring-emerald-200">
              <h3 class="text-2xl text-red-800 sm:text-3xl">
                <i class="fa-brands fa-windows pr-2"></i><i class="fa-brands fa-linux pr-2"></i><i class="fa-brands fa-apple pr-2"></i>
                Windows / Linux / Mac
              </h3>
              <ol class="mt-4 space-y-3 pl-6 text-lg marker:text-red-700 sm:text-xl">
                <li>Download the newest build.</li>
                <li>Extract or move it just like you did the first time.</li>
                <li>Open the new version from its folder or app file.</li>
              </ol>
              <div class="mt-4 rounded-2xl bg-white/80 p-4 text-lg text-gray-800 ring-1 ring-white/70 sm:text-xl">
                Your saves are stored in a different folder, so replacing the
                old build will not remove them. You can safely delete the older
                game files after confirming the new version launches correctly.
              </div>
              <p class="mt-4 text-lg text-gray-800 sm:text-xl">
                One caution: loading a save made in a newer build with an older
                build can cause errors.
              </p>
            </section>

            <section class="rounded-3xl bg-orange-50 p-5 shadow-sm ring-1 ring-orange-200">
              <h3 class="text-2xl text-red-800 sm:text-3xl">
                <i class="fa-solid fa-mobile-screen pr-2"></i>Android
              </h3>
              <div class="mt-4 rounded-2xl bg-red-100 p-4 text-lg text-red-950 ring-1 ring-red-300 sm:text-xl">
                <strong>Do not uninstall the previous app</strong> if you want
                to keep your saves. Uninstalling the old app can delete your
                save data.
              </div>
              <figure class="mt-4 rounded-2xl bg-white/80 p-3 text-center ring-1 ring-white/70">
                <img
                  class="mx-auto rounded-xl"
                  src="/assets/img/sc/android_update.webp"
                  alt="Android update prompt showing the Install button for the new version."
                  loading="lazy"
                />
                <figcaption class="mt-2 text-lg">
                  Open the new .apk, then tap Install.
                </figcaption>
              </figure>
              <p class="mt-4 text-lg text-gray-800 sm:text-xl">
                Download the new .apk and install it over the existing version.
                That keeps your saves in place.
              </p>
            </section>
          </div>
        </section>

        <section
          id="help"
          aria-labelledby="need-help"
          class="rounded-3xl bg-slate-100/90 px-5 py-6 shadow-sm ring-1 ring-slate-200"
        >
          <h2 id="need-help" class="text-center text-3xl sm:text-4xl">
            Need Help?
          </h2>
          <div class="mx-auto mt-4 grid max-w-4xl gap-4 sm:grid-cols-3">
            <a
              href="/stranded.html#download"
              class="rounded-2xl bg-white px-4 py-4 text-center text-lg text-gray-900 shadow-sm ring-1 ring-slate-200 transition duration-150 hover:bg-slate-50 sm:text-xl"
            >
              Return to the Stranded download page
            </a>
            <a
              href="https://discord.gg/4Rp2sVzAHk"
              class="rounded-2xl bg-white px-4 py-4 text-center text-lg text-gray-900 shadow-sm ring-1 ring-slate-200 transition duration-150 hover:bg-slate-50 sm:text-xl"
            >
              Ask for help in Discord
            </a>
            <a
              href="https://github.com/strayproject/strayproject.github.io/releases"
              class="rounded-2xl bg-white px-4 py-4 text-center text-lg text-gray-900 shadow-sm ring-1 ring-slate-200 transition duration-150 hover:bg-slate-50 sm:text-xl"
            >
              Check the latest releases
            </a>
          </div>
        </section>
      </div>
    </div>
  </div>
</BaseLayout>
