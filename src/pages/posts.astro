---
import SheetPageLayout from "../layouts/SheetPageLayout.astro";
import {
  formatPostDate,
  getPostExcerpt,
  getPostPath,
  getSortedPosts,
} from "../lib/posts";

const posts = await getSortedPosts();
---

<SheetPageLayout
  title="Posts"
  description="News from the development team!"
  image="/assets/img/bg/campfire.webp"
>
    <div class="mx-auto flex flex-row items-center justify-center">
      <img class="inline pr-2" src="/assets/img/emotes/dum.webp" alt="" width="64" height="64" />
      <h1 id="download" class="self-center font-boogaloo text-2xl sm:text-3xl">
        Posts
      </h1>
    </div>
    <div class="min-h-screen py-5">
      <ul class="flex flex-col space-y-3 overflow-hidden">
        {posts.map((post) => {
          const primaryTag = post.data.tags[0];

          return (
            <li>
              <a href={getPostPath(post)}>
                <div class="relative min-h-32 w-full rounded-[10px] border border-[rgba(95,121,47,0.2)] bg-[rgba(237,243,228,0.74)] p-4 font-boogaloo shadow-sm transition duration-150 hover:bg-[#edf3e4] sm:p-5">
                  <div class="flex flex-col gap-1 sm:flex-row sm:justify-between sm:gap-4">
                    <h2 class="text-xl leading-tight text-[#20231f] sm:text-2xl">{post.data.title}</h2>
                    <p class="whitespace-nowrap text-sm text-[#4d5049] sm:text-base">
                      {formatPostDate(post.data.pubDate)}
                    </p>
                  </div>
                  <p class="mt-2 pr-28 text-base leading-snug text-[#3f433b] sm:text-lg">
                    {getPostExcerpt(post)}
                  </p>
                  {primaryTag === "stranded" && (
                    <span class="absolute bottom-3 right-3 rounded bg-[#9fbe57] px-2.5 py-0.5 text-sm text-white">
                      STRANDED
                    </span>
                  )}
                  {primaryTag === "admin" && (
                    <span class="absolute bottom-3 right-3 rounded bg-[#5f792f] px-2.5 py-0.5 text-sm text-white">
                      ADMIN
                    </span>
                  )}
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
</SheetPageLayout>
