---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  formatPostDate,
  getPostExcerpt,
  getPostPath,
  getSortedPosts,
} from "../lib/posts";

const posts = await getSortedPosts();
---

<BaseLayout
  title="Posts"
  description="News from the development team!"
  image="/assets/img/bg/campfire.webp"
>
  <div
    class="h-full w-full fixed top-0 -z-10 bg-cover blur-sm"
    style="background-image:url('/assets/img/bg/beach1.webp');"
  ></div>
  <div class="mx-2 md:mx-4 lg:mx-16 xl:mx-32" style="background-color: #fff8;">
    <div class="flex flex-row items-center mx-auto justify-center">
      <img class="inline pr-2" src="/assets/img/emotes/dum.webp" alt="" />
      <h1 id="download" class="text-3xl md:text-3xl lg:text-4xl font-boogaloo self-center">
        Posts
      </h1>
    </div>
    <div class="px-2 sm:px-2 md:px-4 lg:px-6 xl:px-10 py-2 min-h-screen">
      <ul class="flex flex-col overflow-hidden space-y-2">
        {posts.map((post) => {
          const primaryTag = post.data.tags[0];

          return (
            <li>
              <a href={getPostPath(post)}>
                <div class="w-full py-auto lg:px-4 relative rounded-lg h-32 p-2 font-boogaloo bg-blue-100/80 hover:bg-blue-200 transition duration-250">
                  <div class="flex justify-between gap-4">
                    <h1 class="text-xl md:text-2xl lg:text-3xl py-1">{post.data.title}</h1>
                    <p class="text-md lg:text-lg xl:text-xl whitespace-nowrap">
                      {formatPostDate(post.data.pubDate)}
                    </p>
                  </div>
                  <h2 class="text-md lg:text-lg xl:text-xl text-gray-800">
                    {getPostExcerpt(post)}
                  </h2>
                  {primaryTag === "stranded" && (
                    <span class="absolute bottom-1 right-0 bg-green-100 text-green-800 text-md mr-2 px-2.5 py-0.5 rounded dark:bg-green-200 dark:text-green-900">
                      STRANDED
                    </span>
                  )}
                  {primaryTag === "admin" && (
                    <span class="absolute bottom-1 right-0 bg-blue-100 text-blue-800 text-md mr-2 px-2.5 py-0.5 rounded dark:bg-blue-200 dark:text-blue-800">
                      ADMIN
                    </span>
                  )}
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</BaseLayout>
