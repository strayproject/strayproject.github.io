---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found" description="This page does not exist.">
  <div
    class="fixed inset-0 -z-10 bg-cover bg-center"
    style="background-image: url('/assets/stranded/itch/background.webp');"
  ></div>
  <div class="mx-auto max-w-3xl px-4 pt-24 font-boogaloo">
    <div class="stranded-sheet p-8 text-center">
      <p class="text-2xl lg:text-3xl pb-2">
        <i class="fa-solid fa-map-signs pr-2"></i>Page not found
      </p>
      <p class="text-xl lg:text-2xl pb-4">
        The page you were looking for has wandered off.
      </p>
      <a
        href="/index.html"
        class="inline-block bg-gray-500 hover:bg-green-500 transition duration-150 rounded border border-white text-white px-4 sm:px-8 py-1 sm:py-3 text-base"
      >
        Back to home
      </a>
    </div>
  </div>
</BaseLayout>
