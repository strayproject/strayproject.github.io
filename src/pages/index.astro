---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  formatPostDate,
  getPostExcerpt,
  getPostPath,
  getSortedPosts,
} from "../lib/posts";

const posts = await getSortedPosts();
const latestPosts = posts.slice(0, 4);
---

<BaseLayout title="Main Page">
  <div
    class="h-full w-full fixed top-0 -z-10"
    style="background-color: #171717; opacity: 1; background-image: radial-gradient(#926c00 3px, transparent 3px), radial-gradient(#926c00 3px, #171717 3px); background-size: 80px 80px; background-position: 0 0,40px 40px;"
  ></div>
  <div class="container mx-auto">
    <div class="flex flex-row flex-wrap py-4">
      <main role="main" class="flex-auto">
        <div class="mx-auto flex flex-col items-center justify-center">
          <div
            class="relative rounded-lg bg-gradient-to-tl bg-cover from-black container mx-auto flex flex-col items-center shadow-xl py-20"
            style="background-image: url('/assets/img/campfire.webp')"
          >
            <div class="w-11/12 sm:w-2/3 m-10">
              <img
                class="mx-auto justify-self-center"
                src="/assets/img/icon/strandedlogo.webp"
                alt="Stranded logo"
              />
              <h1
                class="text-2xl sm:text-3xl md:text-4xl text-center text-white font-boogaloo text-shadow leading-tight"
              >
                Six Strangers, One Goal.
              </h1>
            </div>
            <div class="flex justify-center items-center">
              <a href="/stranded.html">
                <button
                  class="text-green-700 bg-gray-200/75 hover:bg-green-500 lg:text-2xl hover:border-green-500 hover:text-white transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-offset-2 ring-offset-indigo-700 focus:ring-white hover:bg-indigo-700-800 rounded border border-white px-4 sm:px-8 py-1 sm:py-3 text-md font-boogaloo"
                >
                  {'>'} Main Page
                </button>
              </a>
            </div>
          </div>
          <div
            class="mt-2 relative rounded-lg bg-gradient-to-tl bg-cover from-black container mx-auto flex flex-col items-center shadow-xl py-20"
            style="background-image: url('/assets/img/bg/diner.webp')"
          >
            <div class="w-11/12 sm:w-2/3 m-10">
              <h1
                class="text-4xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl text-center text-white first-line:text-shadow leading-tight"
              >
                WISH DINER
              </h1>
              <h1
                class="text-2xl sm:text-2xl md:text-2xl lg:text-3xl xl:text-4xl text-center text-white text-shadow leading-tight"
              >
                Everything has a price.
              </h1>
            </div>
            <div class="flex justify-center items-center mb-10 sm:mb-20">
              <a href="/wishdiner.html">
                <button
                  class="text-blue-900 bg-gray-200/75 hover:bg-blue-500 lg:text-2xl hover:border-blue-500 hover:text-white transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-offset-2 ring-offset-indigo-700 focus:ring-white hover:bg-indigo-700-800 rounded border border-white px-4 sm:px-8 py-1 sm:py-3 text-md"
                >
                  {'>'} Learn More
                </button>
              </a>
            </div>
          </div>
        </div>
      </main>
      <aside class="flex-auto px-2 font-boogaloo">
        <div class="p-4 mb-2 w-full rounded bg-gray-100/80">
          <div class="w-full h-12 flex">
            <img class="flex-none" src="/assets/img/emotes/dum.webp" alt="" />
            <h1 class="self-center place-self-center text-xl lg:text-2xl">New Posts</h1>
          </div>
          <ul class="flex flex-col overflow-hidden">
            {latestPosts.map((post) => {
              const primaryTag = post.data.tags[0];

              return (
                <li class="pb-1">
                  <a href={getPostPath(post)}>
                    <div class="relative w-full rounded-lg min-h-12 bg-blue-100/80 hover:bg-blue-200 transition duration-250 px-2.5 py-2">
                      {primaryTag === "stranded" && (
                        <span class="absolute bottom-1 right-0 bg-green-100 text-green-800 text-sm font-medium mr-2 px-2.5 py-0.5 rounded dark:bg-green-200 dark:text-green-900">
                          STRANDED
                        </span>
                      )}
                      {primaryTag === "admin" && (
                        <span class="absolute bottom-1 right-0 bg-blue-100 text-blue-800 text-sm font-medium mr-2 px-2.5 py-0.5 rounded dark:bg-blue-200 dark:text-blue-800">
                          ADMIN
                        </span>
                      )}
                      <h2 class="pr-24 text-lg lg:text-xl text-gray-800">{post.data.title}</h2>
                      <p class="text-sm text-gray-600">{formatPostDate(post.data.pubDate)}</p>
                      <p class="text-sm text-gray-700">{getPostExcerpt(post, 12)}</p>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
        <a
          class="twitter-timeline"
          data-height="500"
          data-dnt="true"
          href="https://twitter.com/TheStrayProject?ref_src=twsrc%5Etfw"
        >
          Tweets by TheStrayProject
        </a>
        <script async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
      </aside>
    </div>
  </div>
</BaseLayout>
