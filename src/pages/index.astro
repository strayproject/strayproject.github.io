---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  formatPostDate,
  getPostExcerpt,
  getPostPath,
  getSortedPosts,
} from "../lib/posts";

const posts = await getSortedPosts();
const latestPosts = posts.slice(0, 4);
---

<BaseLayout title="Main Page">
  <div
    class="fixed top-0 -z-10 h-full w-full bg-cover bg-center"
    style="background-image: url('/assets/img/bg/Sky 3.webp');"
  ></div>
  <div class="mx-2 md:mx-4 lg:mx-16 xl:mx-32">
    <div class="flex flex-col gap-4 py-4 lg:flex-row">
      <main role="main" class="min-w-0 flex-[1.75]">
        <div class="mx-auto flex flex-col gap-2">
          <section
            class="relative overflow-hidden rounded-lg bg-gradient-to-tl bg-cover from-black shadow-xl"
            style="background-image: url('/assets/img/campfire.webp')"
          >
            <div class="bg-black/55 px-6 py-16 sm:px-10 lg:px-14 lg:py-24">
              <div class="mx-auto max-w-3xl text-center font-boogaloo text-white">
                <img
                  class="mx-auto mb-6"
                  src="/assets/img/icon/strandedlogo.webp"
                  alt="Stranded logo"
                />
                <p class="text-xl sm:text-2xl lg:text-3xl text-shadow">
                  Five Strangers, One Goal.
                </p>
                <div class="mt-8 flex flex-wrap justify-center gap-3 text-lg sm:text-xl">
                  <a
                    href="/stranded.html"
                    class="rounded-full bg-white/90 px-6 py-3 text-gray-900 transition duration-150 hover:bg-white"
                  >
                    Game Page
                  </a>
                  <a
                    href="/posts.html"
                    class="rounded-full border border-white/80 px-6 py-3 text-white transition duration-150 hover:bg-white/10"
                  >
                    Read Updates
                  </a>
                </div>
              </div>
            </div>
          </section>

        </div>
      </main>
      <aside class="min-w-0 lg:w-[22rem] lg:flex-none font-boogaloo">
        <div class="p-4 mb-2 w-full rounded bg-gray-100/80">
          <div class="w-full h-12 flex">
            <img class="flex-none" src="/assets/img/emotes/dum.webp" alt="" />
            <h1 class="self-center place-self-center text-xl lg:text-2xl">New Posts</h1>
          </div>
          <ul class="flex flex-col overflow-hidden">
            {latestPosts.map((post) => {
              const primaryTag = post.data.tags[0];

              return (
                <li class="pb-1">
                  <a href={getPostPath(post)}>
                    <div class="relative w-full rounded-lg min-h-12 bg-blue-100/80 hover:bg-blue-200 transition duration-250 px-2.5 py-2">
                      {primaryTag === "stranded" && (
                        <span class="absolute bottom-1 right-0 bg-green-100 text-green-800 text-sm font-medium mr-2 px-2.5 py-0.5 rounded dark:bg-green-200 dark:text-green-900">
                          STRANDED
                        </span>
                      )}
                      {primaryTag === "admin" && (
                        <span class="absolute bottom-1 right-0 bg-blue-100 text-blue-800 text-sm font-medium mr-2 px-2.5 py-0.5 rounded dark:bg-blue-200 dark:text-blue-800">
                          ADMIN
                        </span>
                      )}
                      <h2 class="pr-24 text-lg lg:text-xl text-gray-800">{post.data.title}</h2>
                      <p class="text-sm text-gray-600">{formatPostDate(post.data.pubDate)}</p>
                      <p class="text-sm text-gray-700">{getPostExcerpt(post, 12)}</p>
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
