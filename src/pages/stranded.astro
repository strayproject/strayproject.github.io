---
import AudioPlayer from "../components/AudioPlayer.astro";
import { strandedMusicTracks } from "../data/strandedMusic";
import BaseLayout from "../layouts/BaseLayout.astro";

const assets = "/assets/stranded/itch";

const screenshots = [
  {
    src: `${assets}/ss1.webp`,
    alt: "Stranded gameplay screenshot with beach dialogue",
    width: 500,
    height: 300,
  },
  {
    src: `${assets}/ss2.webp`,
    alt: "Stranded gameplay screenshot with close-up dialogue",
    width: 500,
    height: 300,
  },
  {
    src: `${assets}/ss3.webp`,
    alt: "Stranded gameplay screenshot with a toy on the sand",
    width: 500,
    height: 300,
  },
  {
    src: `${assets}/ss4.webp`,
    alt: "Stranded gameplay screenshot with survivors on the island",
    width: 500,
    height: 300,
  },
];

const downloads = [
  {
    label: "Windows / Linux",
    href: "/install.html?download=windows-linux",
    icons: ["fa-brands fa-windows", "fa-brands fa-linux"],
  },
  {
    label: "Mac",
    href: "/install.html?download=mac",
    icons: ["fa-brands fa-apple"],
  },
  {
    label: "Android",
    href: "/install.html?download=android",
    icons: ["fa-brands fa-android"],
  },
  {
    label: "Web Version",
    href: "https://strayproject.github.io/stranded-web/",
    icons: ["fa-solid fa-globe"],
  },
];

const translations = [
  {
    language: "Español [LA]",
    translators: [{ name: "Daro" }, { name: "Kai Oosaki" }],
  },
  {
    language: "Português",
    translators: [
      { name: "E-Arky" },
      { name: "Chase" },
      { name: "Mr P. XIII" },
      { name: "Silyor" },
    ],
  },
  {
    language: "Русский",
    translators: [{ name: "воробей (Vorobei)" }],
  },
  {
    language: "简体中文/繁體中文",
    translators: [
      { name: "泡澡的inko" },
      { name: "DDB", href: "https://t.me/ddbhanhua" },
    ],
  },
  {
    language: "Bulgarian",
    translators: [{ name: "Always has been" }],
  },
];

const patchNotes = [
  {
    version: "v0.3.0 - 25 Apr 2026",
    notes: ["chapter 3 release"],
  },
  {
    version: "v0.2.1 - 6 Oct 2023",
    notes: ["portuguese and chinese translations", "bug fixes"],
  },
  {
    version: "v0.2.0 - 6 Jul 2023",
    notes: ["chapter 2! 12 new cgs."],
  },
  {
    version: "v0.1.2.4 - 18 Sep 2022",
    notes: ["returned spanish (latin america) - thanks daro"],
  },
  {
    version: "v0.1.2.3 - 28 Jun 2022",
    notes: [
      "removed spanish because of incomplete translations",
      "web port: applied lossy compression to backgrounds",
      "fixed russian description display bug",
    ],
  },
  {
    version: "v0.1.2.2 - 9 Jun 2022",
    notes: [
      "added Traditional and Simplified Chinese (thanks to 泡澡的inko)",
      "web port: rearranging audio folder so music and effects are streamed. initial size reduced.",
    ],
  },
  {
    version: "v0.1.2 - 17 May 2022",
    notes: [
      "gui overhaul, movie main menu screen",
      "added Portuguese (thanks to E-Arky, Mr. P. XIII, Sil and Chase)",
      "added Russian (thanks to Vorobei - воробей)",
    ],
  },
  {
    version: "v0.1.1 - 11 Jan 2022",
    notes: ["various bugfixes"],
  },
  {
    version: "v0.1 - 26 Nov 2021",
    notes: ["release of first chapter and character sprites"],
  },
  {
    version: '"Demo" - 24 Jun 2021',
    notes: ["release of prologue without character sprites", "new main menu image"],
  },
];

const socialLinks = [
  {
    label: "Kofi",
    href: "https://ko-fi.com/strayproject",
    icon: "fa-solid fa-mug-hot",
  },
  {
    label: "X",
    href: "https://twitter.com/thestrayproject",
    icon: "fa-brands fa-x-twitter",
  },
  {
    label: "Discord",
    href: "https://discord.gg/4Rp2sVzAHk",
    icon: "fa-brands fa-discord",
  },
  {
    label: "Facebook",
    href: "https://www.facebook.com/TheStrayProject/",
    icon: "fa-brands fa-facebook-f",
  },
];

const castMembers = [
  {
    id: "owen",
    name: "Owen",
    full: "/assets/img/char/owenfull.webp",
    width: 372,
    height: 616,
    species: "Otter",
    age: "21",
    interest: "Fishing",
    description: "Otter with a loud and boisterous attitude. Knows how to fish.",
    quote: "Yeah! No matter what happens, we'll get through this together!",
  },
  {
    id: "terry",
    name: "Terry",
    full: "/assets/img/char/terryfull.webp",
    width: 372,
    height: 616,
    species: "Fox",
    age: "23",
    interest: "Terry",
    description:
      "A cold fox, not of many words. His appearance and behavior seem sharp and distrustful, but is that his true nature?",
    quote: "I'm SO gonna die with these idiots...",
  },
  {
    id: "kim",
    name: "Kim",
    full: "/assets/img/char/kimfull.webp",
    width: 372,
    height: 616,
    species: "Husky",
    age: "25",
    interest: "Sports",
    description:
      "A husky with a mild, optimistic temperament. Has natural leadership abilities and tries his best to keep the team together.",
    quote: "A calm mind is a clear mind.",
  },
  {
    id: "beru",
    name: "Beru",
    full: "/assets/img/char/berufull.webp",
    width: 372,
    height: 616,
    species: "Bear",
    age: "21",
    interest: "Games",
    description:
      "A gamer bear, strong but soft on the inside. Often puts others first. His physical strength is an asset on the island.",
    quote:
      "Well if it's the cold you're worried about, my big fluffy fur can warm you up all night!",
  },
  {
    id: "lucy",
    name: "Lucy",
    full: "/assets/img/char/lucyfull.webp",
    width: 372,
    height: 616,
    species: "Bunny",
    age: "23",
    interest: "Plants",
    description:
      "A rabbit with a lot of smarts. Tends to stutter, but isn't afraid to speak when the situation demands it.",
    quote: "N-No problem. It's the least I can do to help.",
  },
];
---

<BaseLayout
  title="Stranded"
  description="A survival story set on an unknown island."
  image={`${assets}/cover.webp`}
>
  <div class="stranded-page font-boogaloo">
    <div class="min-h-screen px-4 text-[#20231f] sm:px-6 lg:px-10">
      <article class="stranded-sheet mx-auto max-w-[760px] px-5 py-7 sm:px-10 lg:max-w-[920px] lg:px-14 xl:max-w-[1040px]">
        <section class="text-center">
          <img
            class="mx-auto w-full max-w-[620px]"
            src={`${assets}/cover.webp`}
            alt="The Stranded cast"
            width="920"
            height="530"
            loading="eager"
          />
          <img
            class="mx-auto w-full max-w-[560px] sm:mt-4"
            src={`${assets}/stranded-logo.webp`}
            alt="Stranded"
            width="900"
            height="200"
            loading="eager"
          />
          <p class="mt-1 text-sm uppercase tracking-[0.16em] text-[#34372f] sm:text-base">
            A game by The Stray Project
          </p>

          <img class="intro-divider" src={`${assets}/line.webp`} alt="" width="920" height="100" />

          <h1 class="text-2xl text-[#20231f] sm:text-3xl">
            A survival story set on an unknown island!
          </h1>
          <p class="mx-auto mt-4 max-w-[620px] text-base leading-snug sm:text-lg">
            A holiday vacation goe<span class="secret-letter">s</span>{" "}
            completely wrong after your plane crashes onto an unknown island.
            Pl<span class="secret-letter">a</span>y as the protagonist of the story
            who manages to sur<span class="secret-letter">v</span>ive the crash
            along with few oth<span class="secret-letter">e</span>r survivors.
          </p>

          <div class="mt-7 flex flex-wrap justify-center gap-3 text-base sm:text-lg">
            {downloads.map((download) => (
              <a
                class="flex w-full items-center justify-center gap-2 rounded bg-[#9fbe57] px-5 py-2.5 text-white shadow transition duration-150 hover:bg-[#87a743] focus:outline-none focus:ring-2 focus:ring-[#5f792f] focus:ring-offset-2 sm:w-auto"
                href={download.href}
              >
                <span class="inline-flex items-center gap-1.5" aria-hidden="true">
                  {download.icons.map((icon) => (
                    <i class={icon}></i>
                  ))}
                </span>
                <span>{download.label}</span>
              </a>
            ))}
          </div>
          <p class="mt-3 text-sm text-[#4d5049] sm:text-base">
            v0.3.0 | Apr 25, 2026 | <a class="underline hover:text-[#6f8c38]" href="/install.html">Installation Guide</a> | <a class="underline hover:text-[#6f8c38]" href="https://thestrayproject.itch.io/stranded">Itch.io page</a>
          </p>
        </section>

        <section class="section-block text-center">
          <img class="section-divider" src={`${assets}/line.webp`} alt="" width="920" height="100" />
          <h2 class="text-2xl sm:text-3xl">Meet the other survivors!</h2>
          <p class="mx-auto mt-3 max-w-[620px] text-base leading-snug sm:text-lg">
            Decide the fu<span class="secret-letter">t</span>ure of your own
            existence while forging favourable relations<span class="secret-letter">h</span>ips
            with the r<span class="secret-letter">e</span>st of the survivors.
            Their lives co<span class="secret-letter">m</span>pletely rest in your hands.
          </p>
          <img
            class="mx-auto mt-6 w-full max-w-[640px]"
            src={`${assets}/character.webp`}
            alt="The Stranded survivors"
            width="1000"
            height="400"
            loading="lazy"
          />
          <div class="cast-tabs mx-auto mt-6" data-cast-tabs>
            <div class="cast-tab-list" role="tablist" aria-label="Stranded survivors">
              {castMembers.map((member, index) => (
                <button
                  id={`cast-tab-${member.id}`}
                  class={`cast-tab ${index === 0 ? "is-active" : ""}`}
                  type="button"
                  role="tab"
                  aria-selected={index === 0 ? "true" : "false"}
                  aria-controls={`cast-panel-${member.id}`}
                  data-cast-tab={member.id}
                >
                  <span>{member.name}</span>
                </button>
              ))}
            </div>

            {castMembers.map((member, index) => (
              <article
                id={`cast-panel-${member.id}`}
                class="cast-panel"
                role="tabpanel"
                aria-labelledby={`cast-tab-${member.id}`}
                data-cast-panel={member.id}
                hidden={index !== 0}
              >
                <div class="cast-portrait-wrap">
                  <img
                    class="cast-portrait"
                    src={member.full}
                    alt={`${member.name} full character art`}
                    width={member.width}
                    height={member.height}
                    loading="lazy"
                  />
                </div>
                <div class="cast-copy">
                  <h3>{member.name}</h3>
                  <div class="cast-facts" aria-label={`${member.name} details`}>
                    <span>Species: {member.species}</span>
                    <span>Age: {member.age}</span>
                    <span>Interest: {member.interest}</span>
                  </div>
                  <p>{member.description}</p>
                  <blockquote>{member.quote}</blockquote>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="section-block text-center">
          <img class="section-divider" src={`${assets}/line.webp`} alt="" width="920" height="100" />
          <h2 class="text-2xl sm:text-3xl">Preview of the game!</h2>
          <p class="mx-auto mt-3 max-w-[620px] text-base leading-snug sm:text-lg">
            Find the hidden secrets within the unsuspecting island and do your best
            to survive.
          </p>
          <div class="mx-auto mt-6 grid max-w-[660px] gap-3 sm:grid-cols-2">
            {screenshots.map((screenshot, index) => (
              <button
                class="block cursor-zoom-in overflow-hidden rounded-[10px] border-2 border-[#777b77] bg-transparent p-0 shadow-md transition duration-150 hover:brightness-105 focus:outline-none focus:ring-2 focus:ring-[#5f792f] focus:ring-offset-2"
                type="button"
                data-modal-target={`screenshot-modal-${index}`}
                data-modal-toggle={`screenshot-modal-${index}`}
                aria-label={`Open ${screenshot.alt}`}
              >
                <img
                  class="block aspect-[5/3] w-full object-cover"
                  src={screenshot.src}
                  alt={screenshot.alt}
                  width={screenshot.width}
                  height={screenshot.height}
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        </section>

        {screenshots.map((screenshot, index) => (
          <div
            id={`screenshot-modal-${index}`}
            tabindex="-1"
            aria-hidden="true"
            class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto overflow-x-hidden bg-black/80 p-4"
          >
            <div class="relative max-h-full w-full max-w-5xl">
              <button
                type="button"
                class="absolute -right-2 -top-2 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white text-2xl leading-none text-gray-900 shadow transition duration-150 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-white"
                data-modal-hide={`screenshot-modal-${index}`}
                aria-label="Close screenshot preview"
              >
                <span aria-hidden="true">&times;</span>
              </button>
              <img
                class="max-h-[88vh] w-full object-contain"
                src={screenshot.src}
                alt={screenshot.alt}
                width={screenshot.width}
                height={screenshot.height}
                loading="lazy"
              />
            </div>
          </div>
        ))}

        <section class="section-block text-center">
          <img class="section-divider" src={`${assets}/line.webp`} alt="" width="920" height="100" />
          <h2 id="music" class="text-2xl sm:text-3xl">Music</h2>
          <p class="mx-auto mt-3 max-w-[620px] text-base leading-snug sm:text-lg">
            Stranded has 9 original tracks composed by Rex Revon and Zammu!
          </p>
          <AudioPlayer
            id="stranded-music-player"
            tracks={strandedMusicTracks}
            label="Stranded music player"
          />
          <p class="mt-3 text-sm text-[#4d5049] sm:text-base">
            Coming to a streaming platform soon!
          </p>
        </section>

        <section class="section-block text-center">
          <img class="section-divider" src={`${assets}/line.webp`} alt="" width="920" height="100" />
          <h2 id="translations" class="text-2xl sm:text-3xl">Translations</h2>
          <div class="translations-layout mx-auto mt-6">
            <img
              class="translation-image"
              src="/assets/img/sc/tr.webp"
              alt="Stranded language selection screenshot"
              width="1168"
              height="292"
              loading="lazy"
            />
            <div class="translation-copy">
              <p class="text-base leading-snug sm:text-lg">
                Thanks to a fan translation system, Stranded supports multiple languages!
                Enjoy this visual novel in your native language (if it is available)!
                Set it in Options &gt; General &gt; Language.
              </p>
              <div class="translation-table-wrap">
                <table class="translation-table">
                  <thead>
                    <tr>
                      <th>Language</th>
                      <th>Translator(s)</th>
                    </tr>
                  </thead>
                  <tbody>
                    {translations.map((translation) => (
                      <tr>
                        <td>{translation.language}</td>
                        <td>
                          {translation.translators.map((translator, index) => (
                            <>
                              {translator.href ? (
                                <a
                                  class="underline hover:text-[#6f8c38]"
                                  href={translator.href}
                                >
                                  {translator.name}
                                </a>
                              ) : (
                                translator.name
                              )}
                              {index < translation.translators.length - 1 ? ", " : ""}
                            </>
                          ))}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              <p class="mt-3 text-sm text-[#4d5049] sm:text-base">
                To submit typos or translate into your native language, please talk to us via our social media.
              </p>
            </div>
          </div>
        </section>

        <section class="section-block">
          <img class="section-divider" src={`${assets}/line.webp`} alt="" width="920" height="100" />
          <div class="feature-showcase mx-auto">
            <img
              class="feature-side-image feature-side-image-top"
              src="/assets/img/minibg/smoke.webp"
              alt=""
              width="480"
              height="408"
              loading="lazy"
              aria-hidden="true"
            />
            <div class="feature-copy">
              <h2 class="text-xl text-[#40551f] sm:text-2xl">Featuring*:</h2>
              <ul class="feature-list">
                <li>3 chapters (+1 prologue)</li>
                <li>38k words (about 20 mins gameplay)</li>
                <li>lots of art</li>
                <li>9 original music tracks</li>
              </ul>
              <p>* correct as of chapter 3</p>
            </div>
            <img
              class="feature-side-image feature-side-image-bottom"
              src="/assets/img/minibg/sta.webp"
              alt=""
              width="480"
              height="408"
              loading="lazy"
              aria-hidden="true"
            />
          </div>
        </section>

        <section class="section-block text-center">
          <img class="section-divider" src={`${assets}/line.webp`} alt="" width="920" height="100" />
          <h2 class="text-2xl sm:text-3xl">Warning!</h2>
          <p class="mx-auto mt-3 max-w-[620px] text-base leading-snug sm:text-lg">
            This game contains blood, violence, profanity, graphic descriptions of
            deaths, aspects of psychological horror, and features same-sex romance
            between mature furry adults. Viewer discretion is advised.
          </p>
        </section>

        <section class="section-block">
          <img class="section-divider" src={`${assets}/line.webp`} alt="" width="920" height="100" />
          <h2 class="text-center text-2xl sm:text-3xl">Frequently Asked Questions</h2>
          <div class="info-stack mx-auto mt-6">
            <details>
              <summary>Why is this game rated 18 and above?</summary>
              <p>
                Without spoiling too much, please understand that this game contains profanity,
                mention of disturbing events and blood. In addition, as the script progresses,
                more elements will be added to the game that would be considered too strong for
                players under the age of 18. You have been warned!
              </p>
            </details>
            <details>
              <summary>Which version should I download?</summary>
              <ul>
                <li><i class="fa-brands fa-windows" aria-hidden="true"></i> Windows: get the Windows/Linux build, extract and run Stranded.exe</li>
                <li><i class="fa-brands fa-linux" aria-hidden="true"></i> Linux: also get the Windows/Linux build and extract, but run Stranded.sh</li>
                <li><i class="fa-brands fa-apple" aria-hidden="true"></i> Apple Mac computers: get the Mac build, extract and double-click on Stranded.app (allow running apps not from the App Store)</li>
                <li><i class="fa-solid fa-mobile-screen" aria-hidden="true"></i> Android phones: get the Android .apk file, tap to install (allow installing apps from third-party sources)</li>
                <li><i class="fa-solid fa-mobile-button" aria-hidden="true"></i> iOS phones: use the Web version. Stranded will likely never clear App Store requirements.</li>
                <li><i class="fa-solid fa-laptop" aria-hidden="true"></i> Chromebooks: as a first option, download the Android version. If not supported, your second option is to enable Linux and use the Windows/Linux version (run Stranded.sh). Third option: run the Web version.</li>
              </ul>
            </details>
            <details>
              <summary>Why is the itch.io version so old?</summary>
              <p>
                It appears that any and all updates to the itch.io version informs multiple
                people via email, Discord notification via a bot as well as in the launcher
                itself. The updates however are language- and bug-related, and they come quite
                often as opposed to the story updates which take comparatively longer. To try not
                to spam players and give false hope, minor non-story updates are distributed
                through this website.
              </p>
            </details>
            <details>
              <summary>Are you currently accepting fan translations?</summary>
              <p>
                Yes! However we ask you to first negotiate with us via
                <a class="underline hover:text-[#6f8c38]" href="https://discord.gg/4Rp2sVzAHk">Discord</a>
                before starting; by merging your translation efforts into the main application,
                not only do we benefit from a wider reach, but you will also be informed when
                strings are changed, and communication will definitely help with clarifying and
                localizing specific dialogue blocks. (You might even show up in the credits, too!)
              </p>
            </details>
          </div>
        </section>

        <section class="section-block">
          <img class="section-divider" src={`${assets}/line.webp`} alt="" width="920" height="100" />
          <h2 id="patchnotes" class="text-center text-2xl sm:text-3xl">Patch Notes</h2>
          <div class="info-stack mx-auto mt-6">
            {patchNotes.map((patch) => (
              <details>
                <summary>{patch.version}</summary>
                <ul>
                  {patch.notes.map((note) => (
                    <li>{note}</li>
                  ))}
                </ul>
              </details>
            ))}
          </div>
        </section>

        <section class="section-block text-center">
          <img class="section-divider" src={`${assets}/line.webp`} alt="" width="920" height="100" />
          <h2 class="text-2xl sm:text-3xl">A message from The Stray Project!</h2>
          <p class="mt-3 text-base sm:text-lg">Thank you for playing our game.</p>
          <div class="social-links mx-auto mt-7">
            {socialLinks.map((link) => (
              <a class="social-button" href={link.href}>
                <i class={link.icon} aria-hidden="true"></i>
                <span>{link.label}</span>
              </a>
            ))}
          </div>
        </section>
      </article>
    </div>
  </div>

  <style>
    .stranded-page {
      background: url("/assets/stranded/itch/background.webp") center top / cover fixed;
      min-height: 100vh;
    }

    .section-block {
      margin-top: 2.25rem;
    }

    .section-divider,
    .intro-divider {
      display: block;
      margin-left: auto;
      margin-right: auto;
      max-width: 35rem;
      width: 100%;
    }

    .section-divider {
      margin-bottom: 1rem;
    }

    .intro-divider {
      margin-bottom: 1.25rem;
      margin-top: 1.25rem;
    }

    .social-button {
      align-items: center;
      background-color: #9fc160;
      border-radius: 10px;
      color: white;
      display: flex;
      font-size: 1.05rem;
      gap: 0.45rem;
      justify-content: center;
      min-height: 3rem;
      padding: 0.55rem 0.85rem;
      text-transform: uppercase;
      transition:
        background-color 150ms ease,
        transform 150ms ease;
      width: 100%;
    }

    .secret-letter {
      color: #5f7f24;
    }

    :global(.audio-player) {
      margin: 1.5rem auto 0;
    }

    .cast-tabs {
      max-width: 44rem;
    }

    .cast-tab-list {
      display: grid;
      gap: 0.45rem;
      grid-auto-columns: minmax(5.25rem, 1fr);
      grid-auto-flow: column;
      overflow-x: auto;
      padding: 0.15rem 0.15rem 0.35rem;
      scroll-snap-type: x proximity;
    }

    .cast-tab {
      background: rgba(237, 243, 228, 0.74);
      border: 1px solid rgba(95, 121, 47, 0.2);
      border-radius: 10px;
      color: #40551f;
      display: flex;
      justify-content: center;
      min-width: 0;
      overflow: hidden;
      padding: 0.65rem 0.75rem;
      scroll-snap-align: start;
      transition:
        background-color 150ms ease,
        border-color 150ms ease,
        transform 150ms ease;
    }

    .cast-tab:hover,
    .cast-tab:focus-visible,
    .cast-tab.is-active {
      background: rgba(159, 193, 96, 0.22);
      border-color: rgba(95, 121, 47, 0.5);
      outline: none;
    }

    .cast-tab.is-active {
      transform: translateY(-2px);
    }

    .cast-tab span {
      font-size: 1rem;
      line-height: 1;
      overflow-wrap: anywhere;
    }

    .cast-panel {
      align-items: center;
      background: rgba(237, 243, 228, 0.74);
      border: 1px solid rgba(95, 121, 47, 0.2);
      border-radius: 10px;
      display: grid;
      gap: 1rem;
      margin-top: 0.85rem;
      padding: 1rem;
      text-align: left;
    }

    .cast-panel[hidden] {
      display: none;
    }

    .cast-portrait-wrap {
      align-self: stretch;
      background: #f8f8f5;
      border: 1px solid rgba(95, 121, 47, 0.16);
      border-radius: 10px;
      display: flex;
      justify-content: center;
      min-height: 13rem;
      overflow: hidden;
    }

    .cast-portrait {
      max-height: 18rem;
      object-fit: contain;
      object-position: bottom center;
      width: auto;
    }

    .cast-copy h3 {
      color: #20231f;
      font-size: 1.5rem;
      line-height: 1.1;
      text-align: center;
    }

    .cast-facts {
      display: grid;
      gap: 0.4rem;
      margin-top: 0.75rem;
    }

    .cast-facts span {
      background: #f8f8f5;
      border: 1px solid rgba(95, 121, 47, 0.16);
      border-radius: 10px;
      color: #40551f;
      padding: 0.45rem 0.6rem;
      text-align: center;
    }

    .cast-copy p,
    .cast-copy blockquote {
      color: #3f433b;
      font-size: 1rem;
      line-height: 1.35;
      margin-top: 0.8rem;
      text-align: center;
    }

    .cast-copy blockquote {
      color: #4d5049;
      font-style: italic;
    }

    .feature-showcase {
      align-items: center;
      display: grid;
      gap: 1rem;
      justify-items: center;
      max-width: 48rem;
    }

    .feature-side-image {
      max-width: min(16rem, 80vw);
      width: 100%;
    }

    .feature-side-image-top {
      transform: rotate(2deg);
    }

    .feature-side-image-bottom {
      transform: rotate(-2deg);
    }

    .feature-copy {
      color: #20231f;
      text-align: left;
    }

    .feature-list {
      list-style: disc;
      margin-top: 0.75rem;
      padding: 0;
      padding-left: 2rem;
    }

    .feature-list li {
      color: #3f433b;
      font-size: 1rem;
      line-height: 1.35;
      padding-left: 0.5rem;
    }

    .feature-copy p {
      color: #4d5049;
      font-size: 1rem;
      line-height: 1.35;
      margin-top: 0.75rem;
    }

    .translations-layout {
      display: grid;
      gap: 1.25rem;
      max-width: 48rem;
    }

    .translation-image {
      border-radius: 10px;
      border: 1px solid rgba(95, 121, 47, 0.18);
      box-shadow: 0 10px 20px rgba(32, 35, 31, 0.12);
      width: 100%;
    }

    .translation-copy {
      min-width: 0;
    }

    .translation-table-wrap {
      border: 1px solid rgba(95, 121, 47, 0.24);
      border-radius: 10px;
      margin-top: 1rem;
      overflow-x: auto;
    }

    .translation-table {
      background: #f8f8f5;
      border-collapse: collapse;
      font-size: 0.95rem;
      min-width: 42rem;
      text-align: left;
      width: 100%;
    }

    .translation-table th,
    .translation-table td {
      border-bottom: 1px solid rgba(95, 121, 47, 0.16);
      padding: 0.65rem 0.75rem;
      vertical-align: top;
    }

    .translation-table th {
      background: #edf3e4;
      color: #40551f;
      font-weight: 700;
    }

    .translation-table tbody tr:last-child td {
      border-bottom: 0;
    }

    .info-stack {
      display: grid;
      gap: 0.5rem;
      max-width: 48rem;
    }

    .info-stack details {
      background: rgba(237, 243, 228, 0.74);
      border: 1px solid rgba(95, 121, 47, 0.2);
      border-radius: 10px;
      color: #20231f;
      padding: 0.75rem 0.95rem;
    }

    .info-stack details[open] {
      background: rgba(159, 193, 96, 0.18);
      border-color: rgba(95, 121, 47, 0.3);
    }

    .info-stack summary {
      color: #40551f;
      cursor: pointer;
      font-size: 1.15rem;
      line-height: 1.2;
    }

    .info-stack p,
    .info-stack ul {
      color: #3f433b;
      font-size: 1rem;
      line-height: 1.35;
      margin-top: 0.65rem;
    }

    .info-stack ul {
      display: grid;
      gap: 0.35rem;
      list-style: none;
      padding-left: 0;
    }

    .info-stack li i {
      color: #5f792f;
      margin-right: 0.35rem;
      width: 1rem;
    }

    .social-button:hover,
    .social-button:focus-visible {
      background-color: #779350;
      outline: none;
    }

    .social-button:focus-visible {
      box-shadow:
        0 0 0 2px #f8f8f5,
        0 0 0 4px #5f792f;
    }

    .social-button span {
      line-height: 1;
    }

    .social-links {
      display: grid;
      gap: 0.5rem;
      max-width: 18rem;
    }

    @media (min-width: 640px) {
      .cast-tab-list {
        grid-auto-columns: initial;
        grid-auto-flow: row;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        overflow-x: visible;
        padding: 0;
      }

      .cast-panel {
        grid-template-columns: minmax(9rem, 0.8fr) minmax(0, 1.2fr);
      }

      .cast-copy h3,
      .cast-copy p,
      .cast-copy blockquote {
        text-align: left;
      }

      .cast-facts {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .feature-showcase {
        grid-template-columns: minmax(9rem, 1fr) minmax(12rem, auto) minmax(9rem, 1fr);
        max-width: 52rem;
      }

      .feature-side-image {
        max-width: 14rem;
      }

      .social-links {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        max-width: 40rem;
      }
    }

    @media (max-width: 640px) {
      .stranded-page {
        background-attachment: scroll;
        background-position: center top;
      }

    }
  </style>

  <script is:inline>
    document.querySelectorAll("[data-cast-tabs]").forEach((root) => {
      const tabs = Array.from(root.querySelectorAll("[data-cast-tab]"));
      const panels = Array.from(root.querySelectorAll("[data-cast-panel]"));

      const selectTab = (tab) => {
        const selectedId = tab.getAttribute("data-cast-tab");

        tabs.forEach((button) => {
          const isSelected = button === tab;
          button.classList.toggle("is-active", isSelected);
          button.setAttribute("aria-selected", isSelected ? "true" : "false");
        });

        panels.forEach((panel) => {
          panel.hidden = panel.getAttribute("data-cast-panel") !== selectedId;
        });
      };

      tabs.forEach((tab, index) => {
        tab.addEventListener("click", () => selectTab(tab));
        tab.addEventListener("keydown", (event) => {
          const direction = event.key === "ArrowRight" ? 1 : event.key === "ArrowLeft" ? -1 : 0;
          if (!direction) {
            return;
          }

          event.preventDefault();
          const nextTab = tabs[(index + direction + tabs.length) % tabs.length];
          nextTab.focus();
          selectTab(nextTab);
        });
      });
    });

  </script>
</BaseLayout>
