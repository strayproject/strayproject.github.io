---
import "../styles/global.css";

const {
  title,
  description = "Stories, games, and updates from the Stray Project.",
  image,
  showHeader = true,
} = Astro.props;

const siteTitle = "Stray Project";
const pageTitle = title ? `${title} - ${siteTitle}` : siteTitle;
const canonicalUrl = Astro.url.href;
const imageUrl = image
  ? new URL(image, Astro.site ?? Astro.url).toString()
  : undefined;
const currentPath = Astro.url.pathname === "/" ? "/index.html" : Astro.url.pathname;

const navLinks = [
  { href: "/index.html", label: "Home" },
  { href: "/stranded.html", label: "Stranded" },
  { href: "/posts.html", label: "Posts" },
  { href: "/about.html", label: "About Us" },
];

const activeNavLinks = navLinks.map((link) => ({
  ...link,
  isActive:
    currentPath === link.href ||
    (link.href === "/posts.html" && /^\/\d{4}\//.test(currentPath)) ||
    (link.href === "/stranded.html" && currentPath === "/install.html"),
}));

const socialLinks = [
  {
    href: "https://discord.gg/4Rp2sVzAHk",
    img: "/assets/img/icon/discord_icon.webp",
    alt: "Discord",
  },
  {
    href: "https://ko-fi.com/strayproject",
    img: "/assets/img/icon/kofi_icon.webp",
    alt: "Ko-Fi",
  },
  {
    href: "https://twitter.com/thestrayproject",
    img: "/assets/img/icon/twitter_icon.webp",
    alt: "Twitter",
  },
];
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script
      defer
      src="https://kit.fontawesome.com/8c6c4c3a07.js"
      crossorigin="anonymous"
    ></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Boogaloo&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-white focus:px-4 focus:py-2 focus:text-black focus:shadow-lg"
    >
      Skip to main content
    </a>
    <div class="flex min-h-screen flex-col">
      {showHeader && (
        <nav
          aria-label="Primary"
          class="border-b border-[rgba(95,121,47,0.18)] bg-[#f8f8f5]/90 px-3 py-3 font-boogaloo sm:px-4"
        >
          <div class="container flex flex-wrap justify-between items-center mx-auto">
            <a href="/index.html" class="flex items-center gap-2">
              <img
                class="h-8 w-8"
                src="/assets/img/icon/canned_stew.webp"
                alt=""
                width="32"
                height="32"
                aria-hidden="true"
              />
              <span
                class="self-center whitespace-nowrap text-xl font-semibold text-[#20231f] transition duration-200 md:hover:text-[#6f8c38]"
              >
                Stray Project
              </span>
            </a>
            <button
              data-collapse-toggle="mobile-menu"
              type="button"
              class="ml-3 inline-flex items-center rounded-lg p-2 text-sm text-[#40551f] hover:bg-[#edf3e4] focus:outline-none focus:ring-2 focus:ring-[#5f792f] md:hidden"
              aria-controls="mobile-menu"
              aria-expanded="false"
            >
              <span class="sr-only">Open main menu</span>
              <svg class="w-6 h-6" fill="black" viewBox="0 0 20 20" aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"
                  clip-rule="evenodd"
                ></path>
              </svg>
              <svg class="hidden w-6 h-6" fill="black" viewBox="0 0 20 20" aria-hidden="true">
                <path
                  fill-rule="evenodd"
                  d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                  clip-rule="evenodd"
                ></path>
              </svg>
            </button>
            <div class="hidden w-full md:block md:w-auto" id="mobile-menu">
              <ul class="flex flex-col mt-4 md:flex-row md:space-x-8 md:mt-0 md:text-sm md:font-medium">
                {activeNavLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      aria-current={link.isActive ? "page" : undefined}
                      class={`block border-b border-[rgba(95,121,47,0.12)] px-3 py-3 transition duration-200 hover:bg-[#edf3e4] md:border-0 md:p-0 md:text-base md:hover:bg-transparent md:hover:text-[#6f8c38] lg:text-lg ${
                        link.isActive
                          ? "text-[#5f792f] underline decoration-[#9fbe57] decoration-2 underline-offset-4"
                          : "text-[#3f433b]"
                      }`}
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
                <li>
                  <span></span>
                </li>
                <li>
                  <div class="flex py-3 px-3 md:py-0 md:px-0 items-center space-x-4">
                    {socialLinks.map((link) => (
                      <a href={link.href} aria-label={link.alt}>
                        <img
                          class="transition duration-200 ease-in-out transform hover:scale-125"
                          alt={link.alt}
                          src={link.img}
                          width="24"
                          height="24"
                        />
                      </a>
                    ))}
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </nav>
      )}
      <main id="main-content" class="flex-1">
        <slot />
      </main>
      <footer class="border-t border-[rgba(95,121,47,0.18)] bg-[#f8f8f5]/90 p-4 font-boogaloo md:flex md:items-center md:justify-between md:p-6">
        <span class="text-sm text-[#4d5049] sm:text-center">
          Art, story and music © <a href="/index.html" class="hover:underline">
            The Stray Project
          </a>. All Rights Reserved. This website uses third-party cookies from <a
            href="https://help.twitter.com/en/rules-and-policies/twitter-cookies"
            class="hover:underline"
          >
            Twitter
          </a> and <a href="https://itch.io/docs/legal/cookie-policy" class="hover:underline">
            Itch.io
          </a>.
        </span>
        <ul class="mt-3 flex flex-wrap items-center text-sm text-[#4d5049] sm:mt-0">
          <li>
            <a href="https://github.com/strayproject/strayproject.github.io" class="mr-4 hover:underline md:mr-6">
              <i class="fa-brands fa-github pr-2"></i>Source
            </a>
          </li>
        </ul>
      </footer>
    </div>
    <script is:inline src="/assets/js/flowbite.js"></script>
  </body>
</html>
